# ========================
# MASTER MEMBROS — ENV CONFIG
# ========================
# Copie este arquivo para .env e preencha os valores.
# ⚠️  Variáveis sem prefixo VITE_ são BACKEND-ONLY (Edge Functions / servidor).
#     NUNCA adicione prefixo VITE_ a chaves secretas — o Vite as inclui no bundle público.

# App — Nome e URL base da aplicação
VITE_APP_NAME=Master Membros
VITE_APP_URL=http://localhost:5174

# Supabase — URL do projeto e chave anon (painel do Supabase → Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# ⚠️ BACKEND-ONLY — usada apenas em Edge Functions via Deno.env.get()
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 — URL pública usada no frontend para exibir assets
VITE_R2_PUBLIC_URL=
# ⚠️ BACKEND-ONLY — mesmas infos/credenciais usadas apenas em Edge Functions
R2_PUBLIC_URL=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
# Compat legado ainda aceito pela function atual, mas evite em novas configs:
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Resend — ⚠️ BACKEND-ONLY — usada apenas na Edge Function notify-email
RESEND_API_KEY=

# Auth — ⚠️ BACKEND-ONLY — secret para validação de JWT em Edge Functions
JWT_SECRET=

# Pagamentos — Webhooks e chaves de integração com gateway de pagamento
# ⚠️ BACKEND-ONLY — webhooks são processados em Edge Functions
TICTO_WEBHOOK_SECRET=
# ✅ FRONTEND-SAFE — chave pública do Stripe (pode ter VITE_ quando implementado)
VITE_STRIPE_PUBLISHABLE_KEY=

# Feature flags — Controle de comportamento local
# true = habilita logs de debug no console
VITE_DEBUG=false
