# ========================
# LUMI MEMBROS — ENV CONFIG
# ========================
# Copie este arquivo para .env e preencha os valores.

# App — Nome e URL base da aplicação
VITE_APP_NAME=Lumi Membros
VITE_APP_URL=http://localhost:5174

# Supabase — URL do projeto e chave anon (painel do Supabase → Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare R2 — URL pública do bucket e nome do bucket (para uploads de mídia)
VITE_R2_PUBLIC_URL=
VITE_R2_BUCKET_NAME=

# Resend — API key para envio de emails transacionais (boas-vindas, progresso, etc.)
VITE_RESEND_API_KEY=

# Auth — Secret para validação de JWT (quando integrar com Supabase Auth)
VITE_JWT_SECRET=

# Pagamentos — Webhooks e chaves de integração com gateway de pagamento
VITE_TICTO_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Feature flags — Controle de comportamento local
# true = usa dados mock locais em vez de API real
VITE_USE_MOCK_DATA=true
# true = habilita logs de debug no console
VITE_DEBUG=false
